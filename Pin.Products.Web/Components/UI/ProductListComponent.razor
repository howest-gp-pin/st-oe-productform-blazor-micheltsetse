
<div class="row">
    <div class="col col-lg-2">
       
    </div>
</div>
<div class="row">
    <button @onclick="@(()=>OnCreate.InvokeAsync())"> Create New Product</button>
    @foreach (var product in Products)
    {
        <ProductComponent Product="product" OnDelete="OnDelete" OnEdit="OnEdit" OnClick="OnClick" ></ProductComponent>
    }
</div>
@code {
    [Parameter]
    public IEnumerable<ProductModel> Products { get; set; }
    //[Parameter]
    //public EventCallback OnAdd { get; set; }
    [Parameter]
    public EventCallback<int> OnDelete { get; set; }
    [Parameter]
    public EventCallback OnCreate { get; set; }
    [Parameter]
    public EventCallback<ProductModel> OnEdit { get; set; }
    [Parameter]
    public EventCallback<ProductModel> OnClick { get; set; }

    // <button type="button" class="btn btn-outline-info" @onclick="@(() => OnAdd.InvokeAsync())">New</button>
}
